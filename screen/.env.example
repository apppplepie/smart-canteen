# AI 助手（可选）
DEEPSEEK_API_KEY=
VITE_DEEPSEEK_API_KEY=

# 后端 API 地址。不配置则前端使用 mock 数据；配置后菜单、食安、反馈、首页等会请求真实接口
VITE_API_BASE_URL=http://localhost:8081

# 开发：screen 的 Vite 把 /api 代理到 Spring（默认 localhost:8081），避免同站请求落到 5174 报 404
# VITE_DEV_PROXY_TARGET=http://localhost:8081

# TTS：若 Spring 未暴露转发接口，可直连 ai-service（需 CORS 或同源）
# VITE_AI_SERVICE_BASE_URL=http://localhost:8000

# TTS：与 ai-service 豆包音色一致时可填（如 zh_female_shuangkuaisisi）；不设则仅用服务端默认
# VITE_TTS_VOICE=zh_female_shuangkuaisisi
# 调试：TTS 失败时是否回退浏览器系统朗读（生硬、非豆包）。默认不要开
# VITE_TTS_BROWSER_FALLBACK=false
