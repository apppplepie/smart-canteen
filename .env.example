# 复制本文件为 .env（与 docker-compose.yml 同目录）后按需填写。

# 对话与工具：DeepSeek（docker compose 注入 ai-service）
DEEPSEEK_API_KEY=

# 大屏 TTS：火山 OpenSpeech 豆包 2.0（推荐，与 DeepSeek 对话独立）
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_TOKEN=
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_VOICE=zh_female_shuangkuaisisi

# 备选：方舟 /audio/speech（须 TTS 专用接入点）
ARK_API_KEY=
ARK_ENDPOINT_ID=
# ARK_TTS_ENDPOINT_ID=
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# 使用非默认 Docker Hub 命名空间时改为你的用户名（镜像名前缀）
# DOCKERHUB_USER=creepender42

# 仅当使用 docker-compose.frontend.yml 时起三前端 Nginx 时需要：
# Windows / Docker Desktop 上连本机后端建议：
# BACKEND_UPSTREAM=http://host.docker.internal:8081
# FRONTEND_HOST_PORT=9080
