# 后端 API 根地址（AI 对话等请求发往此处，由后端转调 FastAPI）
# 端口要和 Spring Boot 实际运行端口一致，例如 8080 或 8081
VITE_API_BASE_URL="http://localhost:8080"

# APP_URL: The URL where this applet is hosted（可选）
APP_URL="MY_APP_URL"

# 演示：AI 小结「本周热帖」走前端 mock，并纳入 RAG 检索查询（mobile/src/mocks/weeklyHotPostsDemo.ts）
# VITE_DEMO_MOCK_HOT_POSTS="true"
# 或与上一行二选一：统一开 AI 演示（含本周热帖 mock）
# VITE_DEMO_MOCK_AI="true"
