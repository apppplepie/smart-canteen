# ============================================
# SCS 三端前端统一环境变量（admin / screen / mobile）
# 各子项目 vite 已配置为从本目录加载，勿在 admin/.env 等重复配置
# ============================================

# ---------- 公共：后端地址 ----------
# Spring Boot 后端，admin 用代理时写相对路径即可，screen/mobile 直连用此完整 URL
# VITE_API_BASE_URL=http://localhost:8081
# admin 专用：开发时代理目标同上面；聊天接口直连（不配则用上面）
# VITE_CHAT_API_BASE_URL=http://localhost:8081

VITE_API_BASE_URL=http://localhost:8081
VITE_CHAT_API_BASE_URL=http://localhost:8081

# ---------- Docker 三前端容器（docker-compose.frontend*.yml）----------
# Nginx 把浏览器请求 /api/ 反代到这里；与上面 VITE_* 无关（镜像里的 JS 已是构建时写死的同源 /api）。
# 本机后端也在 Docker、端口 8081：Windows/Mac 用 host.docker.internal；纯 Linux 可试 http://172.17.0.1:8081
# 若仍连你云服务器后端，改为：http://74.48.91.105:8081
BACKEND_UPSTREAM=http://host.docker.internal:8081

# ---------- 公共：API Key（仅开发/代理用，勿提交生产密钥）----------
DEEPSEEK_API_KEY=sk-c65e981884294f28a2f9a332f84286c9
VITE_DEEPSEEK_API_KEY=sk-c65e981884294f28a2f9a332f84286c9

# ---------- Docker compose 注入 ai-service：豆包对话 + OpenSpeech TTS ----------
ARK_API_KEY=bKsHYyAa3QASOk9EZxuqE-qclspi65tX
ARK_ENDPOINT_ID=5525475442
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# OpenSpeech TTS：当前代码读取这组 DOUBAO_TTS_*，不再使用方舟 /audio/speech
# 当前切到 2.0 音色，resource_id 使用 seed-tts-2.0
DOUBAO_TTS_APP_ID=5525475442
DOUBAO_TTS_ACCESS_TOKEN=bKsHYyAa3QASOk9EZxuqE-qclspi65tX
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
DOUBAO_TTS_VOICE=zh_male_m191_uranus_bigtts
# ---------- admin 专用 ----------
VITE_APP_TITLE=SCS
VITE_ROUTER_HISTORY=hash
# 连远程后端用完整地址；本地开发连本机后端用 /api/v1（配合 admin vite 代理）
VITE_BASE_URL=/api/v1
VITE_PUBLIC_PATH=/
# VITE_AI_USER_ID=1

