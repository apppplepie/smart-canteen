# ============================================
# SCS 三端前端统一环境变量（admin / screen / mobile）
# 各子项目 vite 已配置为从本目录加载，勿在 admin/.env 等重复配置
# ============================================

# ---------- 公共：后端地址 ----------
# Spring Boot 后端，admin 用代理时写相对路径即可，screen/mobile 直连用此完整 URL
# VITE_API_BASE_URL=http://localhost:8081
# admin 专用：开发时代理目标同上面；聊天接口直连（不配则用上面）
# VITE_CHAT_API_BASE_URL=http://localhost:8081

VITE_API_BASE_URL=http://74.48.91.105:8081
VITE_CHAT_API_BASE_URL=http://74.48.91.105:8081

# ---------- 公共：API Key（仅开发/代理用，勿提交生产密钥）----------
DEEPSEEK_API_KEY=sk-aa2c27e9c32341859faafca54643d9dc
VITE_DEEPSEEK_API_KEY=sk-aa2c27e9c32341859faafca54643d9dc

# ---------- admin 专用 ----------
VITE_APP_TITLE=SCS
VITE_ROUTER_HISTORY=hash
# 连远程后端用完整地址；本地开发连本机后端可改为 /api/v1（配合 vite 代理）
VITE_BASE_URL=http://74.48.91.105:8081/api/v1
VITE_PUBLIC_PATH=/
# VITE_AI_USER_ID=1

# ---------- screen / mobile 可选 ----------
