# 对话与工具调用（必填）
DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1

# ---------- 大屏 TTS 推荐：火山 OpenSpeech（豆包语音合成 2.0，与 DeepSeek 对话无关）----------
# 控制台「语音技术」应用：appid、access_token；resource 如 seed-tts-2.0
DOUBAO_TTS_APP_ID=
DOUBAO_TTS_ACCESS_TOKEN=
DOUBAO_TTS_RESOURCE_ID=seed-tts-2.0
# DOUBAO_TTS_USE_V3=true
# DOUBAO_TTS_CLUSTER=volcano_tts
# DOUBAO_TTS_UID=scs-ai
DOUBAO_TTS_VOICE=zh_female_shuangkuaisisi

# ---------- 备选：方舟 OpenAI 兼容 /audio/speech（须单独 TTS 接入点，勿填对话 ep）----------
ARK_API_KEY=
ARK_ENDPOINT_ID=
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3
# ARK_TTS_ENDPOINT_ID=

# Spring Boot 后端地址，供 Agent 调 API 查库
# 本机直连：http://localhost:8081
# Docker Compose 内已由 compose 注入 http://backend:8081
SPRING_BOOT_BASE_URL=http://localhost:8081
