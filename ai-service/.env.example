# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Spring Boot 后端地址，供 Agent 调 API 查库
# 本机直连：http://localhost:8081
# Docker Compose 内已由 compose 注入 http://backend:8081，勿在容器里写 localhost
SPRING_BOOT_BASE_URL=http://localhost:8081

# 可选：DeepSeek 模型名
# DEEPSEEK_MODEL=deepseek-chat
# 可选：DeepSeek API Base（OpenAI 兼容）
# DEEPSEEK_API_BASE=https://api.deepseek.com/v1
